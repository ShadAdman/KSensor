pipeline {
    agent { label 'windows' }

    environment {
        // The GITHUB_TOKEN should be configured in Jenkins credentials as 'github-token'
        GHA_TOKEN = credentials('github-token')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test Android') {
            steps {
                bat 'gradlew.bat clean ksensor:assembleDebug ksensor:testDebugUnitTest'
            }
        }

        stage('Delegate iOS Build to GitHub') {
            steps {
                script {
                    // Trigger the GitHub Action workflow via KMMBridge
                    def repoOwner = "shadmanadman"
                    def repoName = "KSensor"
                    def workflowFile = "kmm-publish.yml"
                    def branch = env.GIT_BRANCH ?: "main"

                    // Remove 'origin/' prefix if present
                    if (branch.startsWith("origin/")) {
                        branch = branch.substring(7)
                    }

                    echo "Triggering GHA workflow ${workflowFile} on branch ${branch}"

                    bat """
                    curl -L -X POST ^
                    -H "Accept: application/vnd.github+json" ^
                    -H "Authorization: Bearer %GHA_TOKEN%" ^
                    -H "X-GitHub-Api-Version: 2022-11-28" ^
                    https://api.github.com/repos/${repoOwner}/${repoName}/actions/workflows/${workflowFile}/dispatches ^
                    -d "{\\\"ref\\\":\\\"${branch}\\\"}"
                    """
                }
            }
        }
    }
}
